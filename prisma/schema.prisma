generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  name          String
  avatar        String?
  familyMembers FamilyMember[]
  records       Record[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("users")
}

model Family {
  id         String         @id @default(uuid())
  name       String         @default("我的家庭")
  inviteCode String         @unique
  status     FamilyStatus   @default(active)
  maxMembers Int            @default(10)
  members    FamilyMember[]
  records    Record[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@map("families")
}

model FamilyMember {
  id        String             @id @default(uuid())
  familyId  String
  userId    String
  role      FamilyRole?
  status    FamilyMemberStatus @default(active)
  joinedAt  DateTime           @default(now())
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  family    Family             @relation(fields: [familyId], references: [id])
  user      User               @relation(fields: [userId], references: [id])

  @@unique([familyId, userId])
  @@index([userId, status])
  @@map("family_members")
}

model Record {
  id         String      @id @default(uuid())
  familyId    String
  family      Family      @relation(fields: [familyId], references: [id])
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  amount      Decimal     @db.Decimal(10, 2)
  type        RecordType
  category    String
  person      Person
  date        DateTime    @db.Date
  note        String?
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("records")
}

enum FamilyStatus {
  active
  archived
}

enum FamilyMemberStatus {
  pending
  active
  removed
}

enum FamilyRole {
  husband
  wife
  father
  mother
  son
  daughter
  grandfather
  grandmother
  other
}

enum RecordType {
  income
  expense
}

enum Person {
  husband
  wife
  father
  mother
  son
  daughter
  grandfather
  grandmother
  other
}
