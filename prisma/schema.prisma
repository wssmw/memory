generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  name          String
  avatar        String?
  familyMembers FamilyMember[]
  records       Record[]
  diaries       Diary[]
  photos        Photo[]
  wishes        Wish[]
  anniversaries Anniversary[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("users")
}

model Family {
  id            String         @id @default(uuid())
  name          String         @default("我的家庭")
  inviteCode    String         @unique
  status        FamilyStatus   @default(active)
  maxMembers    Int            @default(10)
  members       FamilyMember[]
  records       Record[]
  diaries       Diary[]
  photos        Photo[]
  wishes        Wish[]
  anniversaries Anniversary[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("families")
}

model FamilyMember {
  id        String             @id @default(uuid())
  familyId  String
  userId    String
  role      FamilyRole?
  status    FamilyMemberStatus @default(active)
  joinedAt  DateTime           @default(now())
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  family    Family             @relation(fields: [familyId], references: [id])
  user      User               @relation(fields: [userId], references: [id])

  @@unique([familyId, userId])
  @@index([userId, status])
  @@map("family_members")
}

model Record {
  id        String     @id @default(uuid())
  familyId  String
  family    Family     @relation(fields: [familyId], references: [id])
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  amount    Decimal    @db.Decimal(10, 2)
  type      RecordType
  category  String
  person    Person
  date      DateTime   @db.Date
  note      String?
  deletedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("records")
}

model Diary {
  id        String   @id @default(uuid())
  familyId  String
  family    Family   @relation(fields: [familyId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  content   String   @db.Text
  location  String?
  mood      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([familyId, createdAt])
  @@map("diaries")
}

model Photo {
  id        String   @id @default(uuid())
  familyId  String
  family    Family   @relation(fields: [familyId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  url       String
  title     String?
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([familyId, createdAt])
  @@map("photos")
}

model Wish {
  id          String     @id @default(uuid())
  familyId    String
  family      Family     @relation(fields: [familyId], references: [id])
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  title       String
  description String?    @db.Text
  price       Decimal?   @db.Decimal(10, 2)
  category    String?
  status      WishStatus @default(pending)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([familyId, createdAt])
  @@map("wishes")
}

model Anniversary {
  id          String   @id @default(uuid())
  familyId    String
  family      Family   @relation(fields: [familyId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String
  date        DateTime @db.Date
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([familyId, date])
  @@map("anniversaries")
}

enum FamilyStatus {
  active
  archived
}

enum FamilyMemberStatus {
  pending
  active
  removed
}

enum FamilyRole {
  husband
  wife
  father
  mother
  son
  daughter
  grandfather
  grandmother
  other
}

enum RecordType {
  income
  expense
}

enum Person {
  husband
  wife
  father
  mother
  son
  daughter
  grandfather
  grandmother
  other
}

enum WishStatus {
  pending
  completed
}
